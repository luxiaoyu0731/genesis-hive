# Genesis Hive — 环境变量模板
# 复制此文件为 .env 并填入你的 API Key

OPENROUTER_API_KEY=sk-or-v1-你的key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# OpenRouter 模型 ID 映射（可按需调整）
MODEL_RESEARCH=openai/gpt-4o-mini
MODEL_ANALYSIS=anthropic/claude-sonnet-4
MODEL_ADVERSARY=google/gemini-2.0-flash-001
MODEL_META=anthropic/claude-sonnet-4
MODEL_JUDGE=openai/gpt-4o
MODEL_COMPRESS=openai/gpt-4o-mini

# Token 预算
TOKEN_BUDGET_DEMO=30000
TOKEN_BUDGET_STANDARD=100000
TOKEN_BUDGET_DEEP=250000

# 默认运行模式：demo / standard / deep
DEFAULT_MODE=demo
